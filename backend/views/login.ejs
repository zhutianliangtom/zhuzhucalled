<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>校园失物招领 - 管理后台</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f0f2f5;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .login-container {
      background: #fff;
      padding: 48px 40px;
      border-radius: 8px;
      border: 1px solid #e5e7eb;
      width: 100%;
      max-width: 400px;
    }
    .logo { text-align:center; margin-bottom:36px; }
    .logo h1 { font-size:22px; color:#111; margin-bottom:6px; font-weight:600; }
    .logo p { color:#9ca3af; font-size:13px; }
    .form-group { margin-bottom:20px; }
    .form-group label { display:block; margin-bottom:6px; color:#374151; font-size:13px; font-weight:500; }
    .form-group input {
      width:100%; padding:10px 14px; border:1px solid #d1d5db; border-radius:6px;
      font-size:14px; transition:border-color 0.2s, box-shadow 0.2s;
    }
    .form-group input:focus { outline:none; border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,0.1); }
    .hidden-input { position:absolute; opacity:0; pointer-events:none; height:0; width:0; }
    .btn {
      width:100%; padding:11px; background:#2563eb; color:#fff; border:none;
      border-radius:6px; font-size:14px; font-weight:500; cursor:pointer; transition:background 0.2s;
    }
    .btn:hover { background:#1d4ed8; }
    .error-message {
      background:#fef2f2; color:#991b1b; padding:10px 14px; border-radius:6px;
      font-size:13px; margin-bottom:20px; text-align:center; border:1px solid #fecaca;
    }
    .footer { text-align:center; margin-top:20px; color:#9ca3af; font-size:12px; }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="logo">
      <h1>校园失物招领</h1>
      <p>管理后台</p>
    </div>
    <% if (error) { %>
      <div class="error-message"><%= error %></div>
    <% } %>
    <form action="/admin/login" method="POST" autocomplete="off">
      <input type="text" class="hidden-input" name="fake-username" autocomplete="username">
      <input type="password" class="hidden-input" name="fake-password" autocomplete="current-password">
      <div class="form-group">
        <label>用户名</label>
        <input type="text" name="studentId" placeholder="请输入用户名" required autocomplete="off">
      </div>
      <div class="form-group">
        <label>密码</label>
        <input type="password" name="password" placeholder="请输入密码" required autocomplete="off">
      </div>
      <button type="submit" class="btn">登 录</button>
    </form>
    <div class="footer">请联系系统管理员获取账号</div>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var u = document.querySelector('input[name="studentId"]');
      var p = document.querySelector('input[name="password"]');
      u.setAttribute('autocomplete','nope');
      p.setAttribute('autocomplete','new-password');
      u.addEventListener('focus',function(){this.setAttribute('autocomplete','off')});
      p.addEventListener('focus',function(){this.setAttribute('autocomplete','off')});
      document.querySelector('form').addEventListener('submit',function(){
        u.value=u.value.trim();p.value=p.value.trim();
      });
    });
  </script>
</body>
</html>
