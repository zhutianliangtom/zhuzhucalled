app.get('/items', (req, res) => {
  const { page = 1, pageSize = 10, type = 'all', keyword = '' } = req.query
  
  let items = DB.items.filter(i => i.status === 'active').map(item => {
    const user = DB.users.find(u => u.id === item.userId)
    return {
      ...item,
      userName: user?.name,
      userAvatar: user?.avatar,
      userClassName: user?.className
    }
  })

  if (type !== 'all') items = items.filter(i => i.type === type)
  if (keyword) items = items.filter(i => i.title.includes(keyword) || i.description.includes(keyword))
  items.sort((a, b) => b.createdAt - a.createdAt)

  const start = (page - 1) * pageSize
  res.json({ data: items.slice(start, start + parseInt(pageSize)), total: items.length })
})

