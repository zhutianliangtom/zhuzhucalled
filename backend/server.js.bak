})

app.get('/user/stats', authenticateToken, (req, res) => {
  const userItems = DB.items.filter(i => i.userId === req.user.id)
  
  const stats = {
    total: userItems.length,
    active: userItems.filter(i => i.status === 'active').length,
    solved: userItems.filter(i => i.status === 'solved').length,
    lost: userItems.filter(i => i.type === 'lost').length,
    found: userItems.filter(i => i.type === 'found').length,
    lostActive: userItems.filter(i => i.type === 'lost' && i.status === 'active').length,
    foundActive: userItems.filter(i => i.type === 'found' && i.status === 'active').length,
    lostSolved: userItems.filter(i => i.type === 'lost' && i.status === 'solved').length,
    foundSolved: userItems.filter(i => i.type === 'found' && i.status === 'solved').length
  }
  
  res.json({ data: stats })
})

