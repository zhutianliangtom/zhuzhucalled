  const stats = {
    total: allItems.length,
    active: allItems.filter(i => i.status === 'active').length,
    solved: allItems.filter(i => i.status === 'solved').length,
    lost: allItems.filter(i => i.type === 'lost').length,
    found: allItems.filter(i => i.type === 'found').length,
    lostActive: allItems.filter(i => i.type === 'lost' && i.status === 'active').length,
    foundActive: allItems.filter(i => i.type === 'found' && i.status === 'active').length,
    lostSolved: allItems.filter(i => i.type === 'lost' && i.status === 'solved').length,
    foundSolved: allItems.filter(i => i.type === 'found' && i.status === 'solved').length
  }
  
  res.json({ data: stats })
})

app.post('/upload', authenticateToken, imageUpload.single('image'), (req, res) => {
  if (!req.file) return res.status(400).json({ message: '请选择图片' })
  const url = `http://${localIP}:${port}/uploads/${req.file.filename}`
  res.json({ url })
})

app.post('/upload/video', authenticateToken, videoUpload.single('video'), (req, res) => {
  if (!req.file) return res.status(400).json({ message: '请选择视频' })
  
  const fileSize = req.file.size
  const maxSize = 1024 * 1024 * 1024
  
  if (fileSize > maxSize) {
    fs.unlinkSync(req.file.path)
    return res.status(400).json({ message: '视频大小不能超过1GB' })
  }
  
  const url = `http://${localIP}:${port}/uploads/videos/${req.file.filename}`
  res.json({ url, size: fileSize })
})

app.post('/upload/images', authenticateToken, imageUpload.array('images', 9), (req, res) => {
  if (!req.files || req.files.length === 0) return res.status(400).json({ message: '请选择图片' })
  
  const urls = req.files.map(f => `http://${localIP}:${port}/uploads/${f.filename}`)
  res.json({ urls })
})

app.get('/messages', authenticateToken, (req, res) => {
  const userIds = [...new Set([
    ...DB.messages.filter(m => m.senderId === req.user.id).map(m => m.receiverId),
    ...DB.messages.filter(m => m.receiverId === req.user.id).map(m => m.senderId)
  ])]

  const result = userIds.map(userId => {
    const user = DB.users.find(u => u.id === userId)
    const recentMsg = DB.messages.filter(m => 
      (m.senderId === req.user.id && m.receiverId === userId) ||
      (m.senderId === userId && m.receiverId === req.user.id)
    ).sort((a, b) => b.createdAt - a.createdAt)[0]
    
    const unreadCount = DB.messages.filter(m => 
      m.senderId === userId && 
      m.receiverId === req.user.id && 
      !m.read
    ).length
    
    return { 
      userId, 
      userName: user?.name || '',
      userAvatar: user?.avatar || '',
      lastMessage: recentMsg?.content || '',
      lastTime: recentMsg?.createdAt || 0,
      unread: unreadCount
    }
  })

  res.json({ data: result })
})

// 获取当前用户未读消息总数（用于角标）
app.get('/messages/unread/count', authenticateToken, (req, res) => {
  const count = DB.messages.filter(m =>
    m.receiverId === req.user.id && !m.read
  ).length
  res.json({ data: { count } })
})

app.get('/messages/conversation/:userId', authenticateToken, (req, res) => {
  const messages = DB.messages.filter(m => 
    (m.senderId === req.user.id && m.receiverId === req.params.userId) ||
    (m.senderId === req.params.userId && m.receiverId === req.user.id)
  ).map(m => ({ ...m, createdAt: m.createdAt * 1000 }))

  messages.sort((a, b) => a.createdAt - b.createdAt)
  res.json({ data: messages })
})

app.post('/messages/send', authenticateToken, (req, res) => {
  const { userId, content, type = 'text', mediaUrl = '' } = req.body
  
  if (!userId || (!content && !mediaUrl)) {
    return res.status(400).json({ message: '参数错误' })
  }

  const receiver = DB.users.find(u => u.id === userId)
  if (!receiver) {
    return res.status(404).json({ message: '用户不存在' })
  }

  if (receiver.blockedUsers && receiver.blockedUsers.includes(req.user.id)) {
    return res.status(403).json({ message: '对方已将你拉黑，无法发送消息' })
  }

  const newMsg = {
    id: uuidv4(),
    senderId: req.user.id,
    receiverId: userId,
    content: content || '',
    type,
    mediaUrl,
    createdAt: Math.floor(Date.now() / 1000),
    read: false
  }

  DB.messages.push(newMsg)
  saveData('messages', DB.messages)
  
  res.json({ success: true, message: newMsg })
})

app.put('/messages/:id/recall', authenticateToken, (req, res) => {
  const msg = DB.messages.find(m => m.id === req.params.id)
  if (!msg) return res.status(404).json({ message: '消息不存在' })

  if (msg.senderId !== req.user.id) {
    return res.status(403).json({ message: '无权撤回他人消息' })
  }

  // 已撤回的消息直接返回成功，防止重复请求
  if (msg.type === 'recalled') {
    return res.json({ success: true, message: '已撤回' })
  }

  const now = Math.floor(Date.now() / 1000)
  if (now - msg.createdAt > 120) {
    return res.status(403).json({ message: '超过2分钟，无法撤回' })
  }

  msg.type = 'recalled'
  msg.content = ''
  msg.mediaUrl = ''
  saveData('messages', DB.messages)

  res.json({ success: true, message: '撤回成功' })
})

app.post('/user/block', authenticateToken, (req, res) => {
  const { userId } = req.body
  
  if (!userId) {
    return res.status(400).json({ message: '参数错误' })
  }
  
  const user = DB.users.find(u => u.id === req.user.id)
  if (!user) {
    return res.status(404).json({ message: '用户不存在' })
  }
  
  if (!user.blockedUsers) {
    user.blockedUsers = []
  }
  
  if (!user.blockedUsers.includes(userId)) {
    user.blockedUsers.push(userId)
    saveData('users', DB.users)
  }
  
  DB.messages = DB.messages.filter(m => 
    !(m.senderId === userId && m.receiverId === req.user.id) &&
    !(m.senderId === req.user.id && m.receiverId === userId)
  )
  saveData('messages', DB.messages)
  
  res.json({ success: true, message: '拉黑成功' })
})

app.get('/user/blocked', authenticateToken, (req, res) => {
  const user = DB.users.find(u => u.id === req.user.id)
  res.json({ data: user?.blockedUsers || [] })
})

app.post('/user/unblock', authenticateToken, (req, res) => {
  const { userId } = req.body
  
  if (!userId) {
    return res.status(400).json({ message: '参数错误' })
  }
  
  const user = DB.users.find(u => u.id === req.user.id)
  if (!user || !user.blockedUsers) {
    return res.json({ success: true })
  }
  
  user.blockedUsers = user.blockedUsers.filter(id => id !== userId)
  saveData('users', DB.users)
  
  res.json({ success: true, message: '解除拉黑成功' })
})

app.get('/user/search', authenticateToken, (req, res) => {
  const { keyword } = req.query
  if (!keyword) return res.json({ data: [] })
  
  const users = DB.users.filter(u => 
    u.status === 'approved' && u.id !== req.user.id &&
    (u.name.includes(keyword) || u.studentId.includes(keyword))
  ).map(u => ({ id: u.id, name: u.name, avatar: u.avatar, className: u.className }))
  
  res.json({ data: users })
})

initDatabase()

function getLocalIP() {
  const interfaces = os.networkInterfaces()
  for (const name of Object.keys(interfaces)) {
    for (const iface of interfaces[name]) {
      if (iface.family === 'IPv4' && !iface.internal) {
        return iface.address
      }
    }
  }
  return '127.0.0.1'
}

const localIP = getLocalIP()

const server = app.listen(port, '0.0.0.0', () => {
  console.log(`服务器运行在 http://localhost:${port}`)
  console.log(`局域网访问: http://${localIP}:${port}`)
})

// ─── 版本管理 API ───

// APK 上传目录
const APK_DIR = path.join(__dirname, 'uploads/apk')
if (!fs.existsSync(APK_DIR)) fs.mkdirSync(APK_DIR, { recursive: true })

const apkUpload = multer({
  storage: multer.diskStorage({
    destination: (req, file, cb) => cb(null, APK_DIR),
    filename: (req, file, cb) => {
      const ext = path.extname(file.originalname) || '.apk'
      cb(null, uuidv4() + ext)
    }
  })
})

// 发布新版本（管理员，上传 APK）
app.post('/admin/version/publish', authenticateToken, apkUpload.single('apk'), (req, res) => {
  if (req.user.id !== 'admin') {
    return res.status(403).json({ message: '无权操作' })
  }

  const { version, versionCode, changelog, forceUpdate } = req.body
  if (!version || !versionCode) {
    return res.status(400).json({ message: '版本号和版本码必填' })
  }

  // multer 存的文件无后缀，重命名为 .apk
  let apkUrl = ''
  if (req.file) {
    const ext = '.apk'
    const newPath = path.join(APK_DIR, req.file.filename + ext)
    fs.renameSync(req.file.path, newPath)
    apkUrl = `/uploads/apk/${req.file.filename}${ext}`
  }

  const newVersion = {
    id: uuidv4(),
    version,
    versionCode: parseInt(versionCode),
    changelog: changelog || '',
    apkUrl,
    forceUpdate: forceUpdate === 'true' || forceUpdate === true,
    createdAt: Math.floor(Date.now() / 1000)
  }

  DB.versions.unshift(newVersion)
  if (DB.versions.length > 20) DB.versions = DB.versions.slice(0, 20)
  saveData('versions', DB.versions)

  res.json({ success: true, data: newVersion })
})

// 获取最新版本（App 检测更新用）
app.get('/version/latest', (req, res) => {
  if (DB.versions.length === 0) {
    return res.json({ data: null })
  }
  res.json({ data: DB.versions[0] })
})

// 获取版本列表（官网 / 管理后台用）
app.get('/version/list', (req, res) => {
  const { page = 1, pageSize = 20 } = req.query
  const start = (page - 1) * pageSize
  res.json({
    data: DB.versions.slice(start, start + parseInt(pageSize)),
    total: DB.versions.length
  })
})

// 删除版本
app.delete('/admin/version/:id', authenticateToken, (req, res) => {
  if (req.user.id !== 'admin') {
    return res.status(403).json({ message: '无权操作' })
  }
  DB.versions = DB.versions.filter(v => v.id !== req.params.id)
  saveData('versions', DB.versions)
  res.json({ success: true })
})

// 静态文件：APK 下载
app.use('/uploads/apk', express.static(APK_DIR))