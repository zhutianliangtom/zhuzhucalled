app.put('/items/:id', authenticateToken, (req, res) => {
  const item = DB.items.find(i => i.id === req.params.id)
  if (!item) return res.status(404).json({ message: '物品不存在' })
  
  if (item.userId !== req.user.id && req.user.id !== 'admin') {
    return res.status(403).json({ message: '无权限修改' })
  }

  const { type, title, description, images, contact, status } = req.body
  if (type) item.type = type
  if (title) item.title = title
  if (description) item.description = description
  if (images) item.images = images
  if (contact) item.contact = contact
  if (status) item.status = status
  
  saveData('items', DB.items)
  res.json({ success: true })
})

app.put('/items/:id/solve', authenticateToken, (req, res) => {
  const item = DB.items.find(i => i.id === req.params.id)
  if (!item) return res.status(404).json({ message: '物品不存在' })
  
  if (item.userId !== req.user.id && req.user.id !== 'admin') {
    return res.status(403).json({ message: '无权限操作' })
  }

  item.status = 'solved'
  item.solvedAt = Math.floor(Date.now() / 1000)
  
  saveData('items', DB.items)
  res.json({ success: true })
})

app.delete('/items/:id', authenticateToken, (req, res) => {
  const item = DB.items.find(i => i.id === req.params.id)
  if (!item) return res.status(404).json({ message: '物品不存在' })
  
  if (item.userId !== req.user.id && req.user.id !== 'admin') {
    return res.status(403).json({ message: '无权限删除' })
  }

  DB.items = DB.items.filter(i => i.id !== req.params.id)
  saveData('items', DB.items)
  res.json({ success: true })
})

